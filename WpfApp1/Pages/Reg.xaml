<!-- Pages/Reg.xaml -->
<Page x:Class="WpfApp1.Pages.Reg"
 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
 Title="Регистрация в Хогвартс ✨">

    <Grid Background="#FF500805">

        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="25,15,25,15">

                <!-- 🏰 Заголовок страницы -->
                <TextBlock x:Name="txtTitle"
                    Text="Регистрация нового волшебника 🧙‍♂️"
                    HorizontalAlignment="Center"
                    Foreground="Gold"
                    FontSize="14"
                    FontWeight="Bold"
                    Margin="0,0,0,12"/>

                <!-- 👤 Личные данные -->
                <Border BorderBrush="Gold" BorderThickness="0,0,0,1" Margin="0,0,0,6" Padding="0,0,0,3">
                    <TextBlock Text="Личные данные" Foreground="#FFACB78E" FontSize="13" FontWeight="Bold"/>
                </Border>

                <TextBlock Text="Имя волшебника:" Foreground="White" Margin="0,4,0,2" FontSize="12"/>
                <TextBox x:Name="txtName" Height="24" Margin="0,0,0,6"
                         Background="#FF2C0C0C" Foreground="White" BorderBrush="Gold" FontSize="12"/>

                <TextBlock Text="Дата рождения:" Foreground="White" Margin="0,4,0,2" FontSize="12"/>
                <DatePicker x:Name="dB" Height="24" Margin="0,0,0,6"
                            Background="#FF2C0C0C" BorderBrush="Gold" FontSize="12"/>

                <TextBlock Text="Стаж (лет):" Foreground="White" Margin="0,4,0,2" FontSize="12"/>
                <TextBox x:Name="stag" Height="24" Margin="0,0,0,10"
                         Background="#FF2C0C0C" Foreground="White" BorderBrush="Gold" FontSize="12"/>

                <!-- 🔐 Учетные данные -->
                <Border BorderBrush="Gold" BorderThickness="0,0,0,1" Margin="0,0,0,6" Padding="0,0,0,3">
                    <TextBlock Text="Учетные данные" Foreground="#FFACB78E" FontSize="13" FontWeight="Bold"/>
                </Border>

                <TextBlock Text="Магическое имя (логин):" Foreground="White" Margin="0,4,0,2" FontSize="12"/>
                <TextBox x:Name="txtLogin" Height="24" Margin="0,0,0,6"
                         Background="#FF2C0C0C" Foreground="White" BorderBrush="Gold" FontSize="12"/>

                <TextBlock Text="Защитное заклинание (пароль):" Foreground="White" Margin="0,4,0,2" FontSize="12"/>
                <PasswordBox x:Name="pswPass" Height="24" Margin="0,0,0,6"
                             Background="#FF2C0C0C" Foreground="White" BorderBrush="Gold" FontSize="12"
                             PasswordChanged="pswPass_PasswordChanged"/>

                <TextBlock Text="Повторите заклинание:" Foreground="White" Margin="0,4,0,2" FontSize="12"/>
                <PasswordBox x:Name="pswPass2" Height="24" Margin="0,0,0,10"
                             Background="#FF2C0C0C" Foreground="White" BorderBrush="Gold" FontSize="12"/>

                <!-- 📧 Контактная информация -->
                <Border BorderBrush="Gold" BorderThickness="0,0,0,1" Margin="0,0,0,6" Padding="0,0,0,3">
                    <TextBlock Text="Контактная информация" Foreground="#FFACB78E" FontSize="13" FontWeight="Bold"/>
                </Border>

                <TextBlock Text="Магическая почта:" Foreground="White" Margin="0,4,0,2" FontSize="12"/>
                <TextBox x:Name="txtMail" Height="24" Margin="0,0,0,6"
                         Background="#FF2C0C0C" Foreground="White" BorderBrush="Gold" FontSize="12"/>

                <TextBlock Text="Телефон:" Foreground="White" Margin="0,4,0,2" FontSize="12"/>
                <TextBox x:Name="txtNumber" Height="24" Margin="0,0,0,14"
                         Background="#FF2C0C0C" Foreground="White" BorderBrush="Gold" FontSize="12"/>

                <!-- 🎭 Кнопки -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10">
                    <Button x:Name="btnReg"
                            Content="Стать волшебником ✨"
                            Width="155" Height="32"
                            Margin="0,0,8,0"
                            Background="#FFACB78E"
                            Foreground="#FF500805"
                            FontWeight="Bold"
                            FontSize="12"
                            BorderThickness="0"
                            Click="btnReg_Click"/>
                    <Button x:Name="btnBack"
                            Content="Вернуться ↩️"
                            Width="140" Height="32"
                            Background="#FF78909C"
                            Foreground="White"
                            FontSize="12"
                            BorderThickness="0"
                            Click="btnBack_Click"/>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>

    </Grid>
</Page>
