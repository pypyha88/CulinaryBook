<!-- Pages/Reg.xaml -->
<Page x:Class="WpfApp1.Pages.Reg"
 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
 Title="Регистрация в Хогвартс ✨"
 Width="400" Height="450">

    <Grid Background="#FF500805">

        <!-- 🏰 Заголовок страницы -->
        <TextBlock x:Name="txtTitle"
 Text="Регистрация нового волшебника 🧙♂️"
 Style="{StaticResource Title}"
 HorizontalAlignment="Center"
 VerticalAlignment="Top"
 Margin="0,10,0,0"
 Foreground="Gold"/>

        <!-- 📝 Основной контейнер для полей ввода -->
        <StackPanel Margin="30,50,30,0">

            <!-- 👤 Блок: Личные данные -->
            <Border BorderBrush="Gold"
 BorderThickness="0,0,0,1"
 Margin="0,0,0,10"
 Padding="0,0,0,5">
                <TextBlock Text="Личные данные"
 Foreground="#FFACB78E"
FontSize="16"
FontWeight="Bold"/>
            </Border>

            <!-- Имя волшебника -->
            <TextBlock Text="Имя волшебника:"
 Style="{StaticResource St4}"
 Margin="0,5,0,2"/>
            <TextBox x:Name="txtName"
 Height="25"
 Margin="0,0,0,10"/>

            <!-- Дата рождения -->
            <TextBlock Text="Дата рождения:"
 Style="{StaticResource St4}"
 Margin="0,5,0,2"/>
            <DatePicker x:Name="dB"
 Height="25"
 Margin="0,0,0,10"/>

            <!-- Стаж в магической кулинарии -->
            <TextBlock Text="Стаж (лет):"
 Style="{StaticResource St4}"
 Margin="0,5,0,2"/>
            <TextBox x:Name="stag"
 Height="25"
 Margin="0,0,0,15"/>

            <!-- 🔐 Блок: Учетные данные -->
            <Border BorderBrush="Gold"
 BorderThickness="0,0,0,1"
 Margin="0,0,0,10"
 Padding="0,0,0,5">
                <TextBlock Text="Учетные данные"
 Foreground="#FFACB78E"
FontSize="16"
FontWeight="Bold"/>
            </Border>

            <!-- Магическое имя (логин) -->
            <TextBlock Text="Магическое имя (логин):"
 Style="{StaticResource St4}"
 Margin="0,5,0,2"/>
            <TextBox x:Name="txtLogin"
 Height="25"
 Margin="0,0,0,10"/>

            <!-- Защитное заклинание (пароль) -->
            <TextBlock Text="Защитное заклинание (пароль):"
 Style="{StaticResource St4}"
 Margin="0,5,0,2"/>
            <PasswordBox x:Name="pswPass"
 Height="25"
 Margin="0,0,0,5"
PasswordChanged="pswPass_PasswordChanged"/>

            <!-- Подтверждение заклинания -->
            <TextBlock Text="Повторите заклинание:"
 Style="{StaticResource St4}"
 Margin="0,10,0,2"/>
            <PasswordBox x:Name="pswPass2"
 Height="25"
Margin="0,0,0,15"/>

            <!-- 📧 Блок: Контактная информация -->
            <Border BorderBrush="Gold"
 BorderThickness="0,0,0,1"
 Margin="0,0,0,10"
 Padding="0,0,0,5">
                <TextBlock Text="Контактная информация"
 Foreground="#FFACB78E"
 FontSize="16"
FontWeight="Bold"/>
            </Border>

            <!-- Магическая почта (для сов) -->
            <TextBlock Text="Магическая почта:"
 Style="{StaticResource St4}"
 Margin="0,5,0,2"/>
            <TextBox x:Name="txtMail"
 Height="25"
 Margin="0,0,0,10"/>

            <!-- Телефон (для экстренной связи) -->
            <TextBlock Text="Телефон:"
 Style="{StaticResource St4}"
 Margin="0,5,0,2"/>
            <TextBox x:Name="txtNumber"
 Height="25"
 Margin="0,0,0,20"/>

            <!-- 🎭 Кнопки действий -->
            <StackPanel Orientation="Horizontal"
 HorizontalAlignment="Center"
 Margin="0,10,0,0">
                <Button x:Name="btnReg"
 Content="Стать волшебником ✨"
 Style="{StaticResource MagicButtonStyle}"
 Width="180"
 Height="35"
 Margin="0,0,10,0"
 Click="btnReg_Click"/>

                <Button x:Name="btnBack"
 Content="Вернуться ↩️"
 Style="{StaticResource SecondaryMagicButtonStyle}"
 Width="180"
 Height="35"
 Click="btnBack_Click"/>
            </StackPanel>

        </StackPanel>

    </Grid>
</Page>

