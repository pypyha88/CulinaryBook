<!-- Pages/Autorizaiton.xaml -->
<Page x:Class="WpfApp1.Pages.Autorizaiton"
 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
 Title="Вход в Хогвартс 🏰">

    <Grid Background="#FF500805">

        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="310">

            <!-- 🏰 Заголовок -->
            <TextBlock Text="Кулинарная книга"
                Foreground="Gold"
                FontSize="28"
                FontWeight="Bold"
                HorizontalAlignment="Center"
                Margin="0,0,0,8"/>

            <TextBlock Text="Гарри Поттера 🧙‍♂️"
                Foreground="#FFACB78E"
                FontSize="22"
                HorizontalAlignment="Center"
                Margin="0,0,0,25"/>

            <!-- ✨ Логин -->
            <TextBlock Text="Магическое имя:"
                Foreground="White" FontSize="14" Margin="5,0,5,5"/>
            <TextBox x:Name="txtLogin"
                Width="300" Height="30" Margin="5"
                Background="#FF2C0C0C" Foreground="White"
                BorderBrush="Gold" BorderThickness="1" FontSize="14"/>

            <!-- 🔒 Пароль -->
            <TextBlock Text="Защитное заклинание:"
                Foreground="White" FontSize="14" Margin="5,12,5,5"/>
            <PasswordBox x:Name="txtPassword"
                Width="300" Height="30" Margin="5"
                Background="#FF2C0C0C" Foreground="White"
                BorderBrush="Gold" BorderThickness="1" FontSize="14"/>

            <!-- 🚪 Войти -->
            <Button x:Name="btnVhod"
                Content="Войти в Хогвартс 🚪"
                Width="300" Height="40"
                Margin="5,20,5,8"
                Background="#FFACB78E" Foreground="#FF500805"
                FontSize="16" FontWeight="Bold"
                BorderThickness="0"
                Click="btnVhod_Click"/>

            <!-- 📝 Регистрация -->
            <Button x:Name="btnReg"
                Content="Стать студентом Хогвартса ✨"
                Width="300" Height="38"
                Margin="5,0,5,5"
                Background="#FF78909C" Foreground="White"
                FontSize="14" BorderThickness="0"
                Click="btnReg_Click"/>

            <!-- 🔗 Гиперссылка -->
            <TextBlock HorizontalAlignment="Center" Margin="0,8,0,0"
                Foreground="LightGray" FontSize="12">
                <Hyperlink Click="Hyperlink_Click" Foreground="Gold">
                    Впервые в Хогвартсе? Зарегистрируйтесь!
                </Hyperlink>
            </TextBlock>

        </StackPanel>

    </Grid>
</Page>
