<!-- Pages/Autorizaiton.xaml -->
<Page x:Class="WpfApp1.Pages.Autorizaiton"
 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
 Title="Вход в Хогвартс 🏰" Height="408" Width="308">

    <Grid Background="#FF500805">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">

            <!-- 🏰 Заголовок приложения -->
            <TextBlock Text="Кулинарная книга"
 Foreground="Gold"
 FontSize="28"
 FontWeight="Bold"
 HorizontalAlignment="Center"
 Margin="0,0,0,10"/>

            <TextBlock Text="Гарри Поттера 🧙♂️"
 Foreground="#FFACB78E"
 FontSize="24"
 HorizontalAlignment="Center"
 Margin="0,0,0,30"/>

            <!-- ✨ Поле для магического имени -->
            <TextBlock Text="Магическое имя:"
 Foreground="White"
 FontSize="14"
 Margin="5,0,5,5"/>
            <TextBox x:Name="txtLogin"
 Width="300"
 Height="30"
 Margin="5"
 Background="#FF2C0C0C"
 Foreground="White"
 BorderBrush="Gold"
 BorderThickness="1"
 FontSize="14"/>

            <!-- 🔒 Поле для защитного заклинания -->
            <TextBlock Text="Защитное заклинание:"
 Foreground="White"
 FontSize="14"
 Margin="5,15,5,5"/>
            <PasswordBox x:Name="txtPassword"
 Width="300"
 Height="30"
 Margin="5"
Background="#FF2C0C0C"
 Foreground="White"
BorderBrush="Gold"
 BorderThickness="1"
FontSize="14"/>

            <!-- 🚪 Кнопка входа -->
            <Button x:Name="btnVhod"
 Content="Войти в Хогвартс 🚪"
 Width="300"
 Height="40"
 Margin="5,25,5,10"
 Background="#FFACB78E"
 Foreground="#FF500805"
 FontSize="16"
 FontWeight="Bold"
 BorderThickness="0"
 Click="btnVhod_Click"/>

            <!-- 📝 Кнопка регистрации -->
            <Button x:Name="btnReg"
 Content="Стать студентом Хогвартса ✨"
 Width="300"
 Height="68"
 Margin="5,10,5,5"
 Background="#FF78909C"
 Foreground="White"
 FontSize="14"
 Click="btnReg_Click"/>

        </StackPanel>

        <!-- 🔗 Ссылка на регистрацию -->
        <TextBlock HorizontalAlignment="Center"
 VerticalAlignment="Bottom"
 Margin="0,0,0,20"
 Foreground="LightGray"
 FontSize="12">
 <Hyperlink Click="Hyperlink_Click"
 Foreground="Gold">
 Впервые в Хогвартсе? Зарегистрируйтесь!
 </Hyperlink>
        </TextBlock>
    </Grid>
</Page>
