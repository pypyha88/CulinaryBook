<!-- Pages/PageTask.xaml -->
<Page x:Class="WpfApp1.PageTask" 
xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" 
xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" 
Title="Книга магических рецептов 🧙♂️" 
Width="1200" Height="600">
    <Grid>
        <!-- 🎨 Три строки для разметки -->
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="50"/>
            <!-- 📊 Панель управления -->
            <!-- 📚 Список рецептов -->
            <!-- 📝 Панель состояния -->
        </Grid.RowDefinitions>

        <!-- ✨ Декоративный верхний бордюр -->
        <Border Grid.Row="0" Grid.RowSpan="3"  
                BorderBrush="Gold"  
                BorderThickness="0,0,0,1"/>

        <!-- 🏰 Заголовок страницы -->
        <TextBlock Text="📖 Книга магических рецептов"  
                 
                   Grid.Row="0"  
                   HorizontalAlignment="Left" 
                   Margin="20,0,0,0"/>

        <!-- 📊 ПАНЕЛЬ УПРАВЛЕНИЯ -->
        <Border Grid.Row="0"  
               
                CornerRadius="10" 
                Margin="20,10,20,10">

            <StackPanel Orientation="Horizontal"  
                        VerticalAlignment="Center" 
                        HorizontalAlignment="Center">

                <!-- 🏷 ️ Фильтр по категориям -->
                <StackPanel Orientation="Vertical" Margin="10,0">
                    <TextBlock Text="Категория зелий:"  
                               />
                    <ComboBox x:Name="ComboFilter"  
                              Width="220" 
                              Height="35"  
                              SelectionChanged="ComboFilter_SelectionChanged"/>
                </StackPanel>

                <!-- ⏰ Сортировка -->
                <StackPanel Orientation="Vertical" Margin="10,0">
                    <TextBlock Text="Сортировка:"  
                             />
                    <ComboBox x:Name="ComboSort"  
                              Width="250" 
                              Height="35" 
                              SelectionChanged="ComboSort_SelectionChanged"/>
                </StackPanel>

                <!-- 🔍 Поиск рецептов -->
                <StackPanel Orientation="Vertical" Margin="10,0">
                    <TextBlock Text="Поиск заклинания:"  
                               />
                    <TextBox x:Name="TextSearch"  
                             Width="200" 
                             Height="35"  
                             TextChanged="TextSearch_TextChanged"/>
                </StackPanel>

            </StackPanel>

        </Border>

        <!-- 📚 ОСНОВНОЙ КОНТЕНТ - СПИСОК РЕЦЕПТОВ -->
        <Grid Grid.Row="1" Margin="20,0,20,10">

            <!-- 🎭 КНОПКИ ПЕРЕКЛЮЧЕНИЯ ВИДА -->
            <StackPanel Orientation="Horizontal"  
                        HorizontalAlignment="Right" 
                        VerticalAlignment="Top" 
                        Margin="0,10,10,0">

                <Button x:Name="btnListView"  
                        Content="📋 Список" 
                        Click="Button_Click_List"/>

                <Button x:Name="btnGridView"  
                        Content="🧙 Плитка" 
                        Click="Button_Click_Grid"/>

            </StackPanel>

            <!-- 📖 СПИСОК РЕЦЕПТОВ (ListView) -->
            <ListView x:Name="listProducts"  
                      Margin="0,50,0,0"  
                      MouseDoubleClick="listProducts_MouseDoubleClick">

                <ListView.ItemTemplate>
                    <DataTemplate>
                        <!-- 🍲 КАРТОЧКА РЕЦЕПТА -->
                        <Border>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="200"/>
                                    <!-- 🖼️ Изображение -->
                                    <ColumnDefinition Width="*"/>
                                    <!-- 📝 Описание -->
                                    <ColumnDefinition Width="200"/>
                                    <!-- 🎭 Действия -->
                                </Grid.ColumnDefinitions>

                                <!-- 🖼️ ИЗОБРАЖЕНИЕ РЕЦЕПТА -->
                                <Border Grid.Column="0"  >
                                    <Image Source="{Binding CurrentPhoto}"  />
                                </Border>

                                <!-- 📝 ИНФОРМАЦИЯ О РЕЦЕПТЕ -->
                                <StackPanel Grid.Column="1"  
                                            >

                                    <TextBlock Text="{Binding RecipeName}"  
                                               />

                                    <TextBlock > 
                                        <Run Text="📁 Категория:"/> 
                                        <Run Text="{Binding Categories.CategoryName}"/>
                                    </TextBlock>

                                    <TextBlock > 
                                        <Run Text="📖 Описание:"/> 
                                        <Run Text="{Binding Description}"/>
                                    </TextBlock>

                                    <TextBlock > 
                                        <Run Text="🧙 Время приготовления:"/> 
                                        <Run Text="{Binding CookingTime}"/> 
                                        <Run Text="минут"/>
                                    </TextBlock>

                                </StackPanel>

                                <!-- 🎭 ДЕЙСТВИЯ С РЕЦЕПТОМ -->
                                <StackPanel Grid.Column="2"  
                                            >

                                    <!-- ✏️ Редактировать -->
                                    <Button x:Name="btnEdit"  
                                            Tag="{Binding}"  
                                            Click="btnRed_Click">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="✏️"/>
                                            <TextBlock Text="Редактировать" Margin="5,0,0,0"/>
                                        </StackPanel>
                                    </Button>

                                    <!-- ❤️ В избранное -->
                                    <Button x:Name="btnLike"  
                                            Tag="{Binding}" 
                                            Click="btnLike_Click">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="❤️"/>
                                            <TextBlock Text="В избранное" Margin="5,0,0,0"/>
                                        </StackPanel>
                                    </Button>

                                </StackPanel>

                            </Grid>

                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>

            </ListView>

            <!-- ⏰ ВИД ПЛИТКОЙ (ItemsControl) -->
            <ItemsControl x:Name="myGridView"  
                          Visibility="Collapsed" 
                         >

                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <!-- 🍲 КАРТОЧКА РЕЦЕПТА В ПЛИТКЕ -->
                        <Border>

                            <StackPanel>

                                <!-- 🖼️ Изображение -->
                                <Border>
                                    <Image Source="{Binding CurrentPhoto}"  
/>
                                </Border>

                                <!-- 📝 Информация -->
                                <StackPanel Margin="10">
                                    <TextBlock Text="{Binding RecipeName}"  
                                              />

                                    <TextBlock> 
                                        <Run Text="Категория:"/> 
                                        <Run Text="{Binding Categories.CategoryName}"/>
                                    </TextBlock>

                                    <TextBlock> 
                                        <Run Text="Время:"/> 
                                        <Run Text="{Binding CookingTime}"/> 
                                        <Run Text="мин"/>
                                    </TextBlock>

                                    <!-- 🎭 Кнопки действий -->
                                    <StackPanel Orientation="Horizontal"  
                                                HorizontalAlignment="Center" 
                                                Margin="0,10,0,0">

                                        <Button x:Name="btnGridEdit"  
                                                Tag="{Binding}"  
                                                Click="btnRed_Click" 
                                                ToolTip="Редактировать">
                                            <TextBlock Text="✏️"/>
                                        </Button>

                                        <Button x:Name="btnGridLike"  
                                                Tag="{Binding}" 
                                                Click="btnLike_Click" 
                                                ToolTip="В избранное">
                                            <TextBlock Text="❤️"/>
                                        </Button>

                                    </StackPanel>

                                </StackPanel>

                            </StackPanel>

                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>

            </ItemsControl>

        </Grid>

        <!-- 📝 ПАНЕЛЬ СОСТОЯНИЯ И ДЕЙСТВИЙ -->
        <Border Grid.Row="2"   
                CornerRadius="0,0,10,10" 
                Margin="20,0,20,10">

            <Grid>

                <!-- 📊 СЧЕТЧИК НАЙДЕННЫХ РЕЦЕПТОВ -->
                <StackPanel Orientation="Horizontal"  
                            VerticalAlignment="Center" 
                            HorizontalAlignment="Left" 
                            Margin="20,0,0,0">

                    <TextBlock x:Name="tbCounter"  
                               Text="🔍 Поиск рецептов..." 
/>

                </StackPanel>

                <!-- 🎭 КНОПКИ ДЕЙСТВИЙ -->
                <StackPanel Orientation="Horizontal"  
                            VerticalAlignment="Center" 
                            HorizontalAlignment="Right" 
                            Margin="0,0,20,0">

                    <!-- 📖 Переход в избранное -->
                    <Button x:Name="LikeButton"  
                            Content="❤️ Избранное" 
                            Width="140" 
                            Height="35" 
                            Margin="10,0" 
                            Click="LikeButton_Click"/>

                    <!-- ➕ Добавить новый рецепт -->
                    <Button x:Name="AddButton"  
                            Content="➕ Добавить рецепт" 
                            Width="140" 
                            Height="35" 
                            Margin="10,0" 
                            Click="AddButton_Click"/>

                </StackPanel>

            </Grid>

        </Border>

    </Grid>

</Page> 
